# SupportCopilot — environment variables
# Copy to `.env.local` and fill in real values before running.

# PostgreSQL connection string (Drizzle + better-auth)
# For managed Postgres (Supabase, Neon, etc.) you MUST append ?sslmode=require
# and the app enables TLS automatically in production (see lib/db/index.ts).
DATABASE_URL=postgres://user:password@localhost:5432/supportcopilot?sslmode=require

# Better Auth — REQUIRED in production. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET=replace-with-a-long-random-string
# In production this MUST be your real https URL, not localhost.
BETTER_AUTH_URL=http://localhost:3000

# OpenRouter (AI drafts via chat model — no OpenAI needed)
OPENROUTER_API_KEY=sk-or-...
# Optional: override the chat model (OpenRouter slug). Default: openai/gpt-oss-120b:free
OPENROUTER_MODEL=openai/gpt-oss-120b:free
# Optional: embedding model for KB-aware RAG. OpenRouter has no embeddings,
# so leave unset to disable KB context (draft still generated from the ticket).
# OPENROUTER_EMBED_MODEL=
